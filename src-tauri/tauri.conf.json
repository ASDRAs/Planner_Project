{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Planner Floating",
  "version": "0.1.0",
  "identifier": "com.asdras.plannerfloating",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Planner Floating",
        "width": 420,
        "height": 760,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true,
        "maximizable": false,
        "minimizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
